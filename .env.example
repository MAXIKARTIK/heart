# Copy to `.env` and adjust. Consumed by docker-compose.

# --- PostgreSQL ---
POSTGRES_USER=heart
POSTGRES_PASSWORD=change-me
POSTGRES_DB=heart

# --- API ---
# Set API_KEY to require the `X-API-Key` header on /predict and /batch.
API_KEY=
# Comma-separated allowed CORS origins, or * for any.
CORS_ORIGINS=*
